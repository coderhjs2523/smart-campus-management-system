    <!-- Why choose container/About start -->
<section id="about" class="why_choose_container">

  <div class="why_choose_sub_container">
    <div  class="why_choose">

      <h1>Why Choose Smart Campus</h1>
      <p>Smart Campus is a modern complaint management system designed to improve campus life through digital transparency and efficient issue resolution. We empower students and administration to work together in creating a cleaner, safer, and smarter campus environment.</p>

    </div>

    <div class="why_choose_point">
      <div class="left_data_point">

        <div class="data_point data_point_1">
          <span class="num num1">1</span>
          <h2 class="data_point_data">Easy Complaint Submission</h2>
          <p class="data_point_description">Students can quickly report issues such as water leakage, electrical faults, damaged infrastructure, or cleanliness concerns through a simple and user-friendly interface.</p>
        </div>

        <div class="data_point data_point_2">
          <span class="num num1">2</span>
          <h2 class="data_point_data">Real-Time Tracking</h2>
          <p class="data_point_description">Track complaint status in real-time and stay updated from submission to resolution, ensuring complete transparency in the process.</p>
        </div>

        <div class="data_point data_point_3">
          <span class="num num1">3</span>
          <h2 class="data_point_data">Department-Wise Management</h2>
          <p class="data_point_description">Complaints are automatically assigned to the concerned departments, enabling faster action and efficient handling of campus issues.</p>
        </div>

      </div>

      <a class="why_choose_image_button" href="/">
        <img class="why_choose_image" src="images/logo.png" alt="Smart Campus Logo">
      </a>

      <div class="right_data_point">

        <div class="data_point data_point_4">
          <span class="num">4</span>
          <h2 class="data_point_data">Secure & Reliable System</h2>
          <p class="data_point_description">Built with modern technologies, Smart Campus ensures secure login, protected data storage, and reliable performance.</p>
        </div>

        <div class="data_point data_point_5">
          <span class="num">5</span>
          <h2 class="data_point_data">Faster Issue Resolution</h2>
          <p class="data_point_description">By digitizing the complaint process, issues are resolved more efficiently, reducing delays and improving overall campus maintenance.</p>
        </div>

        <div class="data_point data_point_6">
          <span class="num">6</span>
          <h2 class="data_point_data">Improved Campus Experience</h2>
          <p class="data_point_description">Smart Campus helps create a clean, safe, and well-maintained environment where students can focus on learning and growth.</p>
        </div>

      </div>
    </div>
  </div>

</section>
<!-- why choose container/About end -->

